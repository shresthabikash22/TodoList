<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Collaborative To-Do List — JavaScript</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; color: #1a1a2e; }
        .container { max-width: 1100px; margin: 0 auto; padding: 24px; }

        /* Header */
        .header { background: #2e5c8a; color: white; padding: 20px 24px;
            border-radius: 10px; margin-bottom: 24px; text-align: center}
        .header h1 { font-size: 1.5rem; }
        .header p  { font-size: 0.82rem; opacity: 0.75; margin-top: 4px; }

        /* Stats */
        .stats { display: flex; gap: 14px; margin-bottom: 24px; flex-wrap: wrap; }
        .stat  { flex: 1; min-width: 80px; background: white; border-radius: 8px; padding: 14px;
            text-align: center; box-shadow: 0 1px 4px rgba(0,0,0,0.07); }
        .stat .num { font-size: 1.8rem; font-weight: bold; color: #2e5c8a; }
        .stat .lbl { font-size: 0.78rem; color: #888; margin-top: 3px; }

        /* Flash messages */
        .msg { padding: 11px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 0.9rem; }
        .msg.success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .msg.error   { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

        /* Two column layout */
        .layout { display: grid; grid-template-columns: 1fr 320px; gap: 24px; }
        @media (max-width: 800px) { .layout { grid-template-columns: 1fr; } }

        /* Card */
        .card { background: white; border-radius: 10px; padding: 20px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.07); }
        .card h2 { font-size: 1rem; color: #2e5c8a; margin-bottom: 16px;
            padding-bottom: 10px; border-bottom: 2px solid #eef2f7; }

        /* Task item */
        .task-item { display: flex; align-items: flex-start; gap: 12px;
            padding: 14px 0; border-bottom: 1px solid #f0f2f5; }
        .task-item:last-child { border-bottom: none; }
        .task-info { flex: 1; min-width: 0; }
        .task-title { font-weight: 600; font-size: 0.95rem; }
        .task-title.done { text-decoration: line-through; color: #bbb; }
        .task-desc { font-size: 0.82rem; color: #777; margin-top: 3px; }
        .task-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; align-items: center; }

        /* Badges */
        .badge { display: inline-block; padding: 2px 10px; border-radius: 12px;
            font-size: 0.73rem; font-weight: 600; }
        .cat-WORK     { background: #dbeafe; color: #1e40af; }
        .cat-PERSONAL { background: #fce7f3; color: #9d174d; }
        .cat-URGENT   { background: #fee2e2; color: #991b1b; }
        .cat-OTHER    { background: #e5e7eb; color: #374151; }
        .status-PENDING     { background: #fef3c7; color: #92400e; }
        .status-IN_PROGRESS {
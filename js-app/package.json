{
  "name": "todolist-js",
  "version": "1.0.0",
  "description": "JavaScript implementation of collaborative todo list",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "clean": "echo '[]' > data/users.json && echo '[]' > data/tasks.json && rm -f data/*.lock",
    "clean-start": "npm run clean && npm run dev",
    "fresh": "rm -f data/* && npm run dev"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*.json",
      "data/*.lock",
      "node_modules/*"
    ],
    "watch": [
      "server.js",
      "controllers/",
      "models/",
      "repositories/",
      "services/",
      "views/",
      "init/"
    ],
    "ext": "js,ejs",
    "delay": 1000,
    "verbose": true
  },
  "keywords": [
    "todo",
    "express",
    "ejs"
  ],
  "author": "Bikash & Shruthi",
  "license": "ISC",
  "dependencies": {
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}